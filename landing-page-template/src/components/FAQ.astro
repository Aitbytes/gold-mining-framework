---
// ─── FAQ — BOILERPLATE (do not modify per project) ───────────────────────────
// Pass an array of {q, a} objects as the `items` prop.
// The component renders a native <details>/<summary> accordion — no JS needed.
//
// Usage in index.astro:
//
//   import FAQ from '../components/FAQ.astro';
//
//   const faqs = [
//     { q: "Will this work for me?", a: "Yes, because..." },
//     { q: "How long does it take?", a: "Most users see results in..." },
//   ];
//
//   <FAQ items={faqs} />
//
// Optional props:
//   title   — section heading (default: "Frequently Asked Questions")
//   bgClass — Tailwind background class (default: "bg-white")
// ─────────────────────────────────────────────────────────────────────────────

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
  bgClass?: string;
}

const {
  items,
  title = "Frequently Asked Questions",
  bgClass = "bg-white",
} = Astro.props;
---

<section id="faq" class={`py-16 sm:py-24 px-4 ${bgClass}`}>
  <div class="max-w-3xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-12 sm:mb-16">
      {title}
    </h2>

    <div class="space-y-3">
      {items.map((faq) => (
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center p-5 cursor-pointer bg-surface hover:bg-gray-50 transition-colors list-none select-none">
              <span class="font-semibold text-primary pr-4 leading-snug">
                {faq.q}
              </span>
              <!-- Chevron rotates when open -->
              <span class="flex-shrink-0 text-accent transition-transform duration-200 group-open:rotate-180">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="px-5 pb-5 pt-1 text-text-muted leading-relaxed">
              {faq.a}
            </div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>
